# E2E（Playwright）専用の設定。
# 実際の Supabase / API には接続せず、テスト側でセッションを仕込み、
# /api/** は Playwright のルートハンドラで差し替える。
VITE_API_BASE_URL=http://localhost:5000/api

# ホスト名の先頭ラベル（localhost）が supabase-js の localStorage キーになる。
# → sb-localhost-auth-token（e2e/fixtures/auth.ts と対応させること）
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=e2e-anon-key
